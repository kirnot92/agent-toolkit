<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>AgentToolkit.Mcp</PackageId>
    <Version>0.1.0</Version>
    <Authors>kirnot92</Authors>
    <Description>MCP tool provider integration for AgentToolkit.</Description>
    <PackageTags>agent;llm;tool-calling;mcp;model-context-protocol;ai</PackageTags>
    <PackageProjectUrl>https://github.com/kirnot92/agent-toolkit</PackageProjectUrl>
    <RepositoryUrl>https://github.com/kirnot92/agent-toolkit</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\AgentToolkit\AgentToolkit.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="ModelContextProtocol" Version="1.3.0" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
